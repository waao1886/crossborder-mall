// CrossBorder Mall - Database Schema
// SQLite-based, supports full MVP feature set

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ========== USER & AUTH ==========

model User {
  id               String       @id @default(cuid())
  email            String       @unique
  name             String?
  password         String?
  image            String?
  country          String?
  preferredLang    String       @default("en")
  referralCode     String       @unique
  referredById     String?
  referredBy       User?        @relation("ReferralChain", fields: [referredById], references: [id])
  referralsGiven   User[]       @relation("ReferralChain")

  membership       Membership?
  orders           Order[]
  commissions      Commission[]
  referralRecords  Referral[]   @relation("Referrer")
  referredRecord   Referral?    @relation("Referred")

  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

// ========== MEMBERSHIP & PAYMENT ==========

model Membership {
  id          String       @id @default(cuid())
  userId      String       @unique
  user        User         @relation(fields: [userId], references: [id])
  tier        String       @default("FREE")
  startDate   DateTime     @default(now())
  endDate     DateTime?
  autoRenew   Boolean      @default(false)
  paymentTxs  PaymentTx[]

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model PaymentTx {
  id             String       @id @default(cuid())
  membershipId   String
  membership     Membership   @relation(fields: [membershipId], references: [id])
  txHash         String
  amount         Float
  chain          String       @default("polygon")
  status         String       @default("PENDING")
  verifiedAt     DateTime?
  verifiedBy     String?
  createdAt      DateTime     @default(now())
}

// ========== PRODUCTS ==========

model Product {
  id            String                @id @default(cuid())
  platform      String
  platformId    String
  title         String
  titleEn       String?
  description   String?
  price         Float
  imageUrl      String
  productUrl    String
  category      String?
  rating        Float?
  salesCount    Int?
  translations  ProductTranslation[]

  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
}

model ProductTranslation {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  language    String
  title       String
  description String?

  createdAt   DateTime @default(now())

  @@unique([productId, language])
}

// ========== ORDERS ==========

model Order {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  productId       String
  quantity        Int      @default(1)
  totalPrice      Float
  status          String   @default("PENDING")
  shippingAddress String?
  trackingNumber  String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ========== REFERRAL & COMMISSION ==========

model Referral {
  id           String   @id @default(cuid())
  referrerId   String
  referrer     User     @relation("Referrer", fields: [referrerId], references: [id])
  referredId   String   @unique
  referred     User     @relation("Referred", fields: [referredId], references: [id])
  status       String   @default("PENDING")
  commission   Commission?

  createdAt    DateTime @default(now())
}

model Commission {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  referralId  String   @unique
  referral    Referral @relation(fields: [referralId], references: [id])
  amount      Float
  status      String   @default("PENDING")
  paidAt      DateTime?

  createdAt   DateTime @default(now())
}
